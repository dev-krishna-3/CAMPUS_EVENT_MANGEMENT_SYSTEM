# SMTP Configuration for Email Notifications
# Copy this file as email_config.properties and fill in your details

# Host for SMTP (e.g., smtp.gmail.com)
smtp.host=smtp.gmail.com

# Port (e.g., 587 for TLS or 465 for SSL)
smtp.port=587

# Authentication
smtp.user=your-email@gmail.com
# Use an "App Password" for Gmail, NOT your regular account password
smtp.password=YOUR_APP_PASSWORD_HERE

# From address
smtp.from=your-email@gmail.com

# Use TLS (true/false)
smtp.tls=true
